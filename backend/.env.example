# === D2C Voice-First Agent — Environment Variables ===
# Copy this file to .env and fill in your values.

# Twilio (required)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# Groq (required)
GROQ_API_KEY=your_groq_api_key

# LLM Config (optional — defaults shown)
LLM_MODEL=llama3-70b-8192
LLM_TEMPERATURE=0
WHISPER_MODEL=whisper-large-v3

# Security
# Set to false for local development without ngrok
VALIDATE_TWILIO_SIGNATURE=true
# Your public ngrok/production URL (used for signature validation)
WEBHOOK_BASE_URL=http://localhost:8000

# Database
DATABASE_PATH=d2c_agent.db

# App
APP_VERSION=0.1.0
LOG_LEVEL=INFO
